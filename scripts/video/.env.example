# Franklin Creative Engine — Video Generation (Veo)
# Copie este arquivo para .env e preencha LOCALMENTE.
# NUNCA commite .env — já está no .gitignore

# ─── Gemini API (Google AI Studio) ───
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Modelo Veo — confirmar ID atual na documentação Google
VEO_MODEL=veo-3.0-generate-preview

# Provider: gemini | vertex
VIDEO_PROVIDER=gemini

# ─── Vertex AI (Google Cloud) — opcional ───
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1

# Caminho ABSOLUTO para service account JSON — FORA do repositório
# GOOGLE_APPLICATION_CREDENTIALS=C:\secrets\fce-vertex-sa.json

# Bucket GCS para output (Vertex)
# GCS_OUTPUT_BUCKET=fce-veo-assets

# ─── Geração ───
# Formato prioritário FCE: 9:16 para Reels/TikTok/Shorts
DEFAULT_ASPECT_RATIO=9:16
DEFAULT_DURATION_SECONDS=8

# Resolução alvo (quando suportado pela API)
# DEFAULT_RESOLUTION=1080p

# Takes por cena (iterações)
DEFAULT_TAKES_PER_SCENE=3

# ─── Paths (relativos ao track ou absolutos) ───
# OUTPUT_DIR=../../albums/album-04-o-trono-intocavel/tracks/track-01-o-legado/assets/video/veo3

# ─── Comportamento ───
# Incluir "no text" nos prompts automaticamente (FCE default: true)
ENFORCE_NO_TEXT=true

# Log de geração (sem secrets)
GENERATION_LOG=generation-log.json

# ─── Rate limiting (futuro) ───
# REQUESTS_PER_MINUTE=10
# RETRY_MAX=3
